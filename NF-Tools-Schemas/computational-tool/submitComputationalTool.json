{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submit Computational Tool",
  "type": "object",
  "properties": {
    "basicInfo": {
      "type": "object",
      "title": "Computational Tool Information",
      "properties": {
        "softwareName": {
          "type": "string",
          "title": "Name of Software/Tool"
        },
        "synonyms": {
          "type": "string",
          "title": "Synonyms or Alternative Names"
        },
        "description": {
          "type": "string",
          "title": "Description (~20-50 words)"
        },
        "softwareType": {
          "type": "string",
          "title": "Type of Computational Tool",
          "enum": [
            "Analysis Software",
            "Pipeline",
            "Package/Library",
            "Workflow",
            "Database",
            "Web Application",
            "Command-line Tool",
            "Plugin",
            "Other"
          ]
        },
        "softwareVersion": {
          "type": "string",
          "title": "Current Version"
        },
        "programmingLanguage": {
          "type": "array",
          "title": "Programming Language(s)",
          "items": {
            "type": "string",
            "enum": [
              "Python",
              "R",
              "Java",
              "C++",
              "MATLAB",
              "Julia",
              "Perl",
              "Shell Script",
              "JavaScript",
              "Other"
            ]
          },
          "uniqueItems": true
        },
        "sourceRepository": {
          "type": "string",
          "title": "Source Code Repository URL (e.g., GitHub, GitLab)",
          "format": "uri"
        },
        "documentation": {
          "type": "string",
          "title": "Documentation/User Manual URL",
          "format": "uri"
        },
        "licenseType": {
          "type": "string",
          "title": "Software License",
          "enum": [
            "MIT",
            "Apache 2.0",
            "GPL",
            "BSD",
            "Creative Commons",
            "Proprietary",
            "Other",
            "Unknown"
          ]
        },
        "licenseDetails": {
          "type": "string",
          "title": "License Details",
          "description": "Free-text clarification for non-standard licenses (e.g. non-commercial clauses, third-party tool requirements, or contact info for commercial use). Most relevant when licenseType is 'Other' or 'Proprietary'."
        },
        "containerized": {
          "type": "string",
          "title": "Containerized Version Available?",
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "dependencies": {
          "type": "array",
          "title": "Key Software Dependencies",
          "items": {
            "type": "string"
          }
        },
        "systemRequirements": {
          "type": "string",
          "title": "System Requirements (OS, memory, compute)"
        },
        "lastUpdate": {
          "type": "string",
          "title": "Date of Last Update",
          "format": "date"
        },
        "maintainer": {
          "type": "string",
          "title": "Maintainer Name or Organization"
        },
        "analyticalPlatformSupport": {
          "type": "array",
          "title": "Analytical Platform Support",
          "description": "Experimental data types or analytical platforms this tool is designed to process or integrate.",
          "items": {
            "type": "string",
            "enum": [
              "Mass spectrometry / proteomics",
              "Metabolomics",
              "RNA-seq / transcriptomics",
              "Whole genome / exome sequencing",
              "Single-cell RNA-seq",
              "Imaging / pathology",
              "Pharmacokinetics / PK modeling",
              "Pharmacodynamics / PD modeling",
              "Clinical / EHR data",
              "Other"
            ]
          },
          "uniqueItems": true
        },
        "rrid": {
          "type": "string",
          "title": "RRID (if available)"
        },
        "developerName": {
          "type": "string",
          "title": "Developer Name"
        },
        "developerAffiliation": {
          "type": "string",
          "title": "Developer Affiliation"
        }
      },
      "required": [
        "softwareName",
        "softwareType"
      ]
    },
    "developmentPublicationDOI": {
      "type": "string",
      "title": "Development Publication DOI (where tool was first described)",
      "pattern": "^$|^10\\."
    },
    "usagePublicationDOIs": {
      "type": "array",
      "title": "Usage Publication DOI(s)",
      "items": {
        "type": "string",
        "title": "DOI",
        "pattern": "^$|^10\\."
      }
    },
    "itemAcquisition": {
      "type": "string",
      "title": "How to acquire",
      "enum": [
        "GitHub/GitLab",
        "CRAN",
        "Bioconductor",
        "Docker Hub",
        "PyPI",
        "Contact Developer",
        "Other"
      ]
    },
    "resourceType": {
      "type": "string",
      "title": "Resource Type",
      "default": "Computational Tool"
    },
    "contactEmail": {
      "type": "string",
      "title": "Your Contact Email (optional)",
      "description": "Your email address for follow-up questions about this submission.",
      "format": "email"
    }
  },
  "required": [
    "basicInfo",
    "itemAcquisition"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "enum": [
              "GitHub/GitLab",
              "CRAN",
              "Bioconductor",
              "Docker Hub",
              "PyPI"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "downloadURL": {
            "type": "string",
            "title": "Download/Repository URL",
            "format": "uri"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Contact Developer"
          }
        }
      },
      "then": {
        "properties": {
          "developerContactEmail": {
            "type": "string",
            "title": "Developer Contact Email (optional)",
            "format": "email"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Other"
          }
        }
      },
      "then": {
        "properties": {
          "additionalDetails": {
            "type": "string",
            "title": "Please provide additional details."
          }
        },
        "required": [
          "additionalDetails"
        ]
      }
    }
  ]
}
