{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submit Advanced Cellular Model",
  "type": "object",
  "properties": {
    "basicInfo": {
      "type": "object",
      "title": "Advanced Cellular Model Information",
      "properties": {
        "resourceName": { "type": "string", "title": "Name of Advanced Cellular Model" },
        "synonyms": { "type": "string", "title": "Synonyms" },
        "description": { "type": "string", "title": "Description (~20-50 words)" },
        "modelType": {
          "type": "string",
          "title": "Type of Model",
          "enum": ["Organoid", "Assembloid", "Spheroid", "3D Culture", "Other"]
        },
        "derivationSource": {
          "type": "string",
          "title": "Derivation Source",
          "enum": ["iPSC", "ESC", "Primary Tissue", "Cell Line", "Patient-Derived", "Other"]
        },
        "cellTypes": {
          "type": "array",
          "title": "Cell Types Present",
          "items": { "type": "string" }
        },
        "organoidType": {
          "type": "string",
          "title": "Organoid Type (if applicable)",
          "enum": ["Cerebral", "Intestinal", "Liver", "Kidney", "Cardiac", "Retinal", "Lung", "Pancreatic", "Other"]
        },
        "matrixType": {
          "type": "string",
          "title": "Matrix/Scaffold Type",
          "enum": ["Matrigel", "BME", "Hydrogel", "Synthetic Matrix", "Scaffold-Free", "Other"]
        },
        "cultureSystem": {
          "type": "string",
          "title": "Culture System",
          "enum": ["Static", "Spinning Bioreactor", "Microfluidic", "Air-Liquid Interface", "Other"]
        },
        "cultureMedia": {
          "type": "string",
          "title": "Culture Media",
          "description": "Growth media used to culture this model (e.g. DMEM, RPMI 1640, mTeSR1). Include any supplements such as growth factors, serum, or antibiotics."
        },
        "maturationTime": { "type": "string", "title": "Time Required for Maturation" },
        "characterizationMethods": {
          "type": "array",
          "title": "Characterization Methods Used",
          "items": {
            "type": "string",
            "enum": ["Immunofluorescence", "RNA-seq", "scRNA-seq", "Electrophysiology", "Imaging", "Other"]
          },
          "uniqueItems": true
        },
        "passageNumber": { "type": "string", "title": "Passage Number (if applicable)" },
        "cryopreservationProtocol": { "type": "string", "title": "Cryopreservation Protocol (if available)" },
        "qualityControlMetrics": {
          "type": "array",
          "title": "Quality Control Metrics",
          "items": { "type": "string" }
        },
        "nfGeneticDisorder": {
          "type": "string",
          "title": "NF Genetic Disorder",
          "enum": ["Neurofibromatosis Type 1", "Neurofibromatosis Type 2", "Schwannomatosis", "NF1 Spontaneous Mutation", "None"]
        },
        "nfManifestation": {
          "type": "string",
          "title": "NF Manifestation",
          "enum": [
            "Plexiform Neurofibroma", "Cutaneous Neurofibroma", "Atypical Neurofibroma",
            "Malignant Peripheral Nerve Sheath Tumor", "Schwannoma", "Meningioma",
            "Low Grade Glioma", "High Grade Glioma", "Optic Nerve Glioma",
            "Pheochromocytoma", "Cognition", "Other", "None"
          ]
        },
        "rrid": { "type": "string", "title": "RRID (if available)" },
        "developerName": { "type": "string", "title": "Developer Name" },
        "developerAffiliation": { "type": "string", "title": "Developer Affiliation" }
      },
      "required": ["modelName", "modelType", "derivationSource", "cellTypes", "howToAcquire"]
    },
    "developmentPublicationDOI": {
      "type": "string",
      "title": "Development Publication DOI (where tool was first described)"
    },
    "usagePublicationDOIs": {
      "type": "string",
      "title": "Usage Publication DOI(s) where tool was used (separate multiple with commas)"
    }
  },
  "required": ["basicInfo", "itemAcquisition"],
  "allOf": [
    {
      "if": { "properties": { "itemAcquisition": { "const": "Contact Developer" } } },
      "then": {
        "properties": {
          "developerContactEmail": { "type": "string", "title": "Developer Contact Email (optional)", "format": "email" }
        }
      }
    },
    {
      "if": { "properties": { "itemAcquisition": { "const": "Purchase from Vendor" } } },
      "then": {
        "properties": {
          "vendor": { "type": "string", "title": "Vendor Name" },
          "catalogNumber": { "type": "string", "title": "Catalog Number" },
          "catalogURL": { "type": "string", "title": "Link to vendor page" }
        }
      }
    },
    {
      "if": { "properties": { "itemAcquisition": { "const": "Other" } } },
      "then": {
        "properties": {
          "additionalDetails": { "type": "string", "title": "Please provide additional details." }
        },
        "required": ["additionalDetails"]
      }
    }
  ]
}
