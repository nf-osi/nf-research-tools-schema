    "cultureMedia": {
      "ui:widget": "textarea",
      "ui:placeholder": "e.g. mTeSR1 supplemented with growth factors",
      "ui:options": { "rows": 3 }
    },
    "characterizationMethods": { "ui:widget": "checkboxes" },
    "cryopreservationProtocol": { "ui:widget": "textarea" },
    "qualityControlMetrics": { "ui:options": { "orderable": false } },
