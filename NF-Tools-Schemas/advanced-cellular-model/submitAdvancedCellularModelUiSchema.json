      "description",
      "modelType",
      "derivationSource",
      "cellTypes",
      "organoidType",
      "matrixType",
      "cultureSystem",
      "cultureMedia",
      "maturationTime",
      "characterizationMethods",
      "passageNumber",
      "cryopreservationProtocol",
