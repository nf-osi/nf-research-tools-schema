{
  "basicInfo": {
    "ui:order": [
      "resourceName",
      "synonyms",
      "description",
      "modelSystemType",
      "patientDiagnosis",
      "hostStrain",
      "passageNumber",
      "tumorType",
      "engraftmentSite",
      "establishmentRate",
      "molecularCharacterization",
      "clinicalData",
      "humanizationMethod",
      "immuneSystemComponents",
      "validationMethods",
      "species",
      "sex",
      "race",
      "age",
      "nfGeneticDisorder",
      "rrid",
      "developerName",
      "developerAffiliation"
    ],
    "description": { "ui:widget": "textarea" },
    "patientDiagnosis": { "ui:widget": "textarea" },
    "molecularCharacterization": { "ui:widget": "checkboxes" },
    "clinicalData": { "ui:widget": "textarea" },
    "humanizationMethod": { "ui:widget": "textarea" },
    "immuneSystemComponents": { "ui:options": { "orderable": false } },
    "validationMethods": { "ui:options": { "orderable": false } },
    "species": {
      "ui:widget": "radio",
      "ui:options": { "inline": true }
    },
    "sex": {
      "ui:widget": "radio",
      "ui:options": { "inline": true }
    },
    "race": {
      "ui:widget": "select"
    },
    "age": {
      "ui:widget": "updown"
    },
    "nfGeneticDisorder": {
      "ui:widget": "select"
    }
  },
  "bbbIntegrityStatus": {
    "ui:widget": "select"
  },
  "routeOfAdministration": {
    "ui:widget": "checkboxes"
  },
  "pkpdCapabilities": {
    "ui:widget": "checkboxes"
  },
  "mechanismOfActionValidation": {
    "ui:widget": "checkboxes"
  },
  "pediatricSuitability": {
    "ui:widget": "radio"
  },
  "timelineToResults": {
    "ui:widget": "select"
  },
  "modelLimitations": {
    "ui:widget": "textarea",
    "ui:options": { "rows": 3 }
  },
  "clinicalTranslationHistory": {
    "ui:widget": "textarea",
    "ui:options": { "rows": 3 }
  },
  "regulatoryAcceptanceHistory": {
    "ui:widget": "textarea",
    "ui:options": { "rows": 3 }
  },
  "developmentPublicationDOI": {
    "ui:placeholder": "e.g. 10.1000/xyz123"
  },
  "usagePublicationDOIs": {
    "ui:options": { "addButtonText": "Add Another DOI", "itemTitle": "DOI", "orderable": false }
  },
  "itemAcquisition": { "ui:widget": "radio" },
  "developerContactEmail": {
    "ui:placeholder": "developer@institution.edu"
  },
  "vendor": {
    "ui:placeholder": "e.g. vendor name"
  },
  "catalogURL": {
    "ui:placeholder": "https://"
  },
  "additionalDetails": {
    "ui:widget": "textarea",
    "ui:options": { "rows": 3 }
  },
  "contactEmail": {
    "ui:placeholder": "your@email.com"
  },
  "resourceType": { "ui:widget": "hidden" }
