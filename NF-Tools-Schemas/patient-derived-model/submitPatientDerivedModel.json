{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submit Patient-Derived Model",
  "type": "object",
  "properties": {
    "basicInfo": {
      "type": "object",
      "title": "Patient-Derived Model Information",
      "properties": {
        "resourceName": { "type": "string", "title": "Name of Patient-Derived Model" },
        "synonyms": { "type": "string", "title": "Synonyms" },
        "description": { "type": "string", "title": "Description (~20-50 words)" },
        "modelSystemType": {
          "type": "string",
          "title": "Model System Type",
          "enum": ["PDX (Patient-Derived Xenograft)", "Humanized Mouse", "Patient-Derived Organoid", "Patient-Derived Cell Line", "Other"]
        },
        "patientDiagnosis": { "type": "string", "title": "Patient Diagnosis/Condition" },
        "hostStrain": {
          "type": "string",
          "title": "Host Strain (for xenografts)",
          "enum": ["NSG", "NOD-SCID", "nude", "SCID", "Other"]
        },
        "passageNumber": { "type": "string", "title": "Current Passage Number" },
        "tumorType": {
          "type": "string",
          "title": "Tumor Type (if applicable)",
          "enum": ["Cutaneous Neurofibroma", "Plexiform Neurofibroma", "Atypical Neurofibroma", "Schwannoma", "Meningioma", "Malignant Peripheral Nerve Sheath Tumor", "Low Grade Glioma", "High Grade Glioma", "Pheochromocytoma", "Optic Nerve Glioma", "Other"]
        },
        "engraftmentSite": {
          "type": "string",
          "title": "Engraftment Site",
          "enum": ["Subcutaneous", "Orthotopic", "Intracranial", "Mammary Fat Pad", "Other"]
        },
        "establishmentRate": { "type": "string", "title": "Establishment/Success Rate" },
        "molecularCharacterization": {
          "type": "array",
          "title": "Molecular Characterization Performed",
          "items": {
            "type": "string",
            "enum": ["Genomic Sequencing", "RNA-seq", "Proteomics", "Immunohistochemistry", "Other"]
          },
          "uniqueItems": true
        },
        "clinicalData": { "type": "string", "title": "Available Clinical Data from Patient" },
        "humanizationMethod": { "type": "string", "title": "Humanization Method (if applicable)" },
        "immuneSystemComponents": {
          "type": "array",
          "title": "Human Immune System Components Present",
          "items": { "type": "string" }
        },
        "validationMethods": {
          "type": "array",
          "title": "Validation Methods Used",
          "items": { "type": "string" }
        },
        "species": {
          "type": "string",
          "title": "Species",
          "enum": ["Human", "Mouse", "Other"]
        },
        "sex": {
          "type": "string",
          "title": "Sex",
          "enum": ["Male", "Female", "Unknown"]
        },
        "race": {
          "type": "string",
          "title": "Race",
          "enum": [
            "American Indian or Alaska Native", "Asian", "Black or African American",
            "Native Hawaiian or Other Pacific Islander", "White", "Hispanic or Latino",
            "Middle Eastern or North African", "Multiracial", "Other", "Not specified"
          ]
        },
        "age": {
          "type": "number",
          "title": "Patient Age at Collection (years)",
          "minimum": 0,
          "maximum": 120
        },
        "nfGeneticDisorder": {
          "type": "string",
          "title": "NF Genetic Disorder",
          "enum": ["Neurofibromatosis Type 1", "Neurofibromatosis Type 2", "Schwannomatosis", "NF1 Spontaneous Mutation", "None"]
        },
        "rrid": { "type": "string", "title": "RRID (if available)" },
        "developerName": { "type": "string", "title": "Developer Name" },
        "developerAffiliation": { "type": "string", "title": "Developer Affiliation" }
      },
      "required": ["modelName", "modelSystemType", "patientDiagnosis", "howToAcquire"]
    },
    "developmentPublicationDOI": {
      "type": "string",
      "title": "Development Publication DOI (where tool was first described)"
    },
    "usagePublicationDOIs": {
      "type": "string",
      "title": "Usage Publication DOI(s) where tool was used (separate multiple with commas)"
    }
  },
  "required": ["basicInfo", "itemAcquisition"],
  "allOf": [
    {
      "if": { "properties": { "itemAcquisition": { "const": "Contact Developer" } } },
      "then": {
        "properties": {
          "developerContactEmail": { "type": "string", "title": "Developer Contact Email (optional)", "format": "email" }
        }
      }
    },
    {
      "if": { "properties": { "itemAcquisition": { "const": "Purchase from Vendor" } } },
      "then": {
        "properties": {
          "vendor": { "type": "string", "title": "Vendor Name" },
          "catalogNumber": { "type": "string", "title": "Catalog Number" },
          "catalogURL": { "type": "string", "title": "Link to vendor page" }
        }
      }
    },
    {
      "if": { "properties": { "itemAcquisition": { "const": "Other" } } },
      "then": {
        "properties": {
          "additionalDetails": { "type": "string", "title": "Please provide additional details." }
        },
        "required": ["additionalDetails"]
      }
    }
  ]
}
