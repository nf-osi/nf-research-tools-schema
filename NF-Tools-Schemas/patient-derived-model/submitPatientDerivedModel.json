{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submit Patient-Derived Model",
  "type": "object",
  "properties": {
    "basicInfo": {
      "type": "object",
      "title": "Patient-Derived Model Information",
      "properties": {
        "resourceName": {
          "type": "string",
          "title": "Name of Patient-Derived Model"
        },
        "synonyms": {
          "type": "string",
          "title": "Synonyms"
        },
        "description": {
          "type": "string",
          "title": "Description (~20-50 words)"
        },
        "modelSystemType": {
          "type": "string",
          "title": "Model System Type",
          "enum": [
            "PDX (Patient-Derived Xenograft)",
            "Patient-Derived Organoid",
            "Other"
          ]
        },
        "patientDiagnosis": {
          "type": "string",
          "title": "Patient Diagnosis/Condition"
        },
        "hostStrain": {
          "type": "string",
          "title": "Host Strain (for xenografts)",
          "enum": [
            "NSG",
            "NOD-SCID",
            "nude",
            "SCID",
            "Other"
          ]
        },
        "passageNumber": {
          "type": "string",
          "title": "Current Passage Number"
        },
        "tumorType": {
          "type": "string",
          "title": "Tumor Type (if applicable)",
          "enum": [
            "Cutaneous Neurofibroma",
            "Plexiform Neurofibroma",
            "Atypical Neurofibroma",
            "Schwannoma",
            "Meningioma",
            "Malignant Peripheral Nerve Sheath Tumor",
            "Low Grade Glioma",
            "High Grade Glioma",
            "Pheochromocytoma",
            "Optic Nerve Glioma",
            "Other"
          ]
        },
        "engraftmentSite": {
          "type": "string",
          "title": "Engraftment Site",
          "enum": [
            "Subcutaneous",
            "Orthotopic",
            "Intracranial",
            "Mammary Fat Pad",
            "Other"
          ]
        },
        "establishmentRate": {
          "type": "string",
          "title": "Establishment/Success Rate"
        },
        "molecularCharacterization": {
          "type": "array",
          "title": "Molecular Characterization Performed",
          "items": {
            "type": "string",
            "enum": [
              "Genomic Sequencing",
              "Whole Genome Sequencing",
              "Whole Exome Sequencing",
              "RNA sequencing",
              "Proteomics",
              "Immunohistochemistry",
              "Flow Cytometry",
              "Methylation",
              "Other"
            ]
          },
          "uniqueItems": true
        },
        "clinicalData": {
          "type": "string",
          "title": "Available Clinical Data from Patient"
        },
        "validationMethods": {
          "type": "array",
          "title": "Validation Methods Used",
          "items": {
            "type": "string"
          }
        },
        "species": {
          "type": "string",
          "title": "Species",
          "enum": [
            "Human",
            "Mouse",
            "Other"
          ]
        },
        "sex": {
          "type": "string",
          "title": "Sex",
          "enum": [
            "Male",
            "Female",
            "Unknown"
          ]
        },
        "race": {
          "type": "string",
          "title": "Race",
          "enum": [
            "American Indian or Alaska Native",
            "Asian",
            "Black or African American",
            "Native Hawaiian or Other Pacific Islander",
            "White",
            "Hispanic or Latino",
            "Middle Eastern or North African",
            "Multiracial",
            "Other",
            "Not specified"
          ]
        },
        "age": {
          "type": "number",
          "title": "Patient Age at Collection (years)",
          "minimum": 0,
          "maximum": 120
        },
        "nfGeneticDisorder": {
          "type": "string",
          "title": "NF Genetic Disorder",
          "enum": [
            "Neurofibromatosis Type 1",
            "Neurofibromatosis Type 2",
            "Schwannomatosis",
            "NF1 Spontaneous Mutation",
            "None"
          ]
        },
        "rrid": {
          "type": "string",
          "title": "RRID (if available)"
        },
        "developerName": {
          "type": "string",
          "title": "Developer Name"
        },
        "developerAffiliation": {
          "type": "string",
          "title": "Developer Affiliation"
        }
      },
      "required": [
        "resourceName",
        "modelSystemType",
        "patientDiagnosis",
        "species",
        "nfGeneticDisorder"
      ]
    },
    "bbbIntegrityStatus": {
      "type": "string",
      "title": "Blood-Brain Barrier Integrity",
      "description": "Whether the blood-brain barrier is intact, compromised, or not applicable in this model.",
      "enum": [
        "",
        "Intact",
        "Compromised",
        "Not Applicable",
        "Unknown"
      ]
    },
    "routeOfAdministration": {
      "type": "array",
      "title": "Supported Drug Administration Routes",
      "description": "Drug delivery routes that have been validated or are feasible in this model.",
      "items": {
        "type": "string",
        "enum": [
          "Oral",
          "Intravenous (IV)",
          "Intraperitoneal (IP)",
          "Intracranial",
          "Subcutaneous",
          "Topical",
          "Intranasal",
          "Other"
        ]
      },
      "uniqueItems": true
    },
    "pkpdCapabilities": {
      "type": "array",
      "title": "PK/PD Measurement Capabilities",
      "description": "Pharmacokinetic and pharmacodynamic measurements that can be performed in this model.",
      "items": {
        "type": "string",
        "enum": [
          "Drug concentration in plasma",
          "Drug concentration in brain/CNS tissue",
          "Drug concentration in tumor",
          "Drug concentration in CSF",
          "Target engagement measurement",
          "Pathway modulation (e.g., pERK, pAKT)",
          "Biomarker response",
          "Metabolite profiling",
          "Metabolic pathway flux analysis",
          "Drug-drug interaction assessment",
          "Other"
        ]
      },
      "uniqueItems": true
    },
    "mechanismOfActionValidation": {
      "type": "array",
      "title": "Validated Drug Mechanisms",
      "description": "Drug mechanisms of action that have been successfully tested in this model.",
      "items": {
        "type": "string",
        "enum": [
          "MEK inhibitors",
          "RAS pathway (non-MEK)",
          "mTOR inhibitors",
          "VEGF/angiogenesis",
          "CDK inhibitors",
          "HDAC inhibitors",
          "Other kinase inhibitors",
          "Immunotherapy",
          "Chemotherapy",
          "Other"
        ]
      },
      "uniqueItems": true
    },
    "pediatricSuitability": {
      "type": "string",
      "title": "Age Relevance",
      "description": "Whether this model is suitable for studying pediatric, adult, or both age groups.",
      "enum": [
        "",
        "Pediatric",
        "Adult",
        "Both",
        "Unknown"
      ]
    },
    "timelineToResults": {
      "type": "string",
      "title": "Typical Timeline to Results",
      "description": "Estimated time from experiment start to primary endpoint readout.",
      "enum": [
        "",
        "Less than 1 month",
        "1–3 months",
        "3–6 months",
        "6–12 months",
        "More than 12 months",
        "Unknown"
      ]
    },
    "modelLimitations": {
      "type": "string",
      "title": "Known Model Limitations",
      "description": "Explicit description of what this model does NOT recapitulate or where it may produce false positive/negative results."
    },
    "clinicalTranslationHistory": {
      "type": "string",
      "title": "Clinical Translation History",
      "description": "Known instances where findings from this model did or did not translate to human clinical outcomes."
    },
    "regulatoryAcceptanceHistory": {
      "type": "string",
      "title": "Regulatory Acceptance History",
      "description": "Known FDA/EMA precedents where data from this model type supported a regulatory submission or approval."
    },
    "mtaRequired": {
      "type": "boolean",
      "title": "MTA Required?",
      "description": "Whether a Material Transfer Agreement is required to access this model."
    },
    "ngnriRepositoryStatus": {
      "type": "boolean",
      "title": "Deposited in NGNRI Repository?",
      "description": "Whether this model is deposited in the NF Gene Network Research Initiative repository for equitable access."
    },
    "developmentPublicationDOI": {
      "type": "string",
      "title": "Development Publication DOI (where tool was first described)",
      "pattern": "^$|^10\\."
    },
    "usagePublicationDOIs": {
      "type": "array",
      "title": "Usage Publication DOI(s)",
      "items": {
        "type": "string",
        "title": "DOI",
        "pattern": "^$|^10\\."
      }
    },
    "itemAcquisition": {
      "type": "string",
      "title": "How to acquire",
      "enum": [
        "Contact Developer",
        "Purchase from Vendor",
        "Other"
      ],
      "default": "Contact Developer"
    },
    "resourceType": {
      "type": "string",
      "title": "Resource Type",
      "default": "Patient-Derived Model"
    },
    "contactEmail": {
      "type": "string",
      "title": "Your Contact Email (optional)",
      "description": "Your email address for follow-up questions about this submission.",
      "format": "email"
    }
  },
  "required": [
    "basicInfo",
    "itemAcquisition"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Contact Developer"
          }
        }
      },
      "then": {
        "properties": {
          "developerContactEmail": {
            "type": "string",
            "title": "Developer Contact Email (optional)",
            "format": "email"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Purchase from Vendor"
          }
        }
      },
      "then": {
        "properties": {
          "vendor": {
            "type": "string",
            "title": "Vendor Name"
          },
          "catalogNumber": {
            "type": "string",
            "title": "Catalog Number"
          },
          "catalogURL": {
            "type": "string",
            "title": "Link to vendor page"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Other"
          }
        }
      },
      "then": {
        "properties": {
          "additionalDetails": {
            "type": "string",
            "title": "Please provide additional details."
          }
        },
        "required": [
          "additionalDetails"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "modelSystemType": {
                "const": "Other"
              }
            },
            "required": [
              "modelSystemType"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "modelSystemTypeOther": {
                "type": "string",
                "title": "Please specify model system type"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "hostStrain": {
                "const": "Other"
              }
            },
            "required": [
              "hostStrain"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "hostStrainOther": {
                "type": "string",
                "title": "Please specify host strain"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "tumorType": {
                "const": "Other"
              }
            },
            "required": [
              "tumorType"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "tumorTypeOther": {
                "type": "string",
                "title": "Please specify tumor type"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "engraftmentSite": {
                "const": "Other"
              }
            },
            "required": [
              "engraftmentSite"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "engraftmentSiteOther": {
                "type": "string",
                "title": "Please specify engraftment site"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "species": {
                "const": "Other"
              }
            },
            "required": [
              "species"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "speciesOther": {
                "type": "string",
                "title": "Please specify species"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "race": {
                "const": "Other"
              }
            },
            "required": [
              "race"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "raceOther": {
                "type": "string",
                "title": "Please specify race/ethnicity"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "molecularCharacterization": {
                "contains": {
                  "const": "Other"
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "otherMolecularCharacterization": {
                "type": "string",
                "title": "Please specify other molecular characterization method(s)"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "routeOfAdministration": {
            "contains": {
              "const": "Other"
            }
          }
        }
      },
      "then": {
        "properties": {
          "otherRouteOfAdministration": {
            "type": "string",
            "title": "Please specify other route(s) of administration"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mechanismOfActionValidation": {
            "contains": {
              "const": "Other"
            }
          }
        }
      },
      "then": {
        "properties": {
          "otherMechanismOfActionValidation": {
            "type": "string",
            "title": "Please specify other mechanism(s) of action"
          }
        }
      }
    }
  ]
}
