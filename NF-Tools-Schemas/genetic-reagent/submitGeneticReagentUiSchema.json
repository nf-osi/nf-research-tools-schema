      "rows": 3
    }
  },
  "cloningMethod": {
    "ui:widget": "radio",
    "ui:inline": "true"
  },
  "5primeSiteDestroyed": {
    "ui:widget": "radio",
    "ui:inline": "true"
  },
  "3primeSiteDestroyed": {
    "ui:widget": "radio",
    "ui:inline": "true"
  },
  "vectorType": {
    "ui:widget": "select"
  },
  "bacterialResistance": {
    "ui:widget": "checkboxes"
  },
  "selectableMarker": {
    "ui:widget": "checkboxes"
  },
  "copyNumber": {
    "ui:widget": "radio"
  },
  "growthTemp": {
    "ui:widget": "radio"
  },
  "growthStrain": {
    "ui:widget": "select"
  },
