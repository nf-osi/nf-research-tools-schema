  "catalogURL": {
    "ui:placeholder": "https://"
  },
  "additionalDetails": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 3
    }
  },
  "contactEmail": {
    "ui:placeholder": "your@email.com"
  },
