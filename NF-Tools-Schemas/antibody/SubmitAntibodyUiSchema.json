{
  "basicInfo": {
    "description": {
      "ui:widget": "textarea",
      "ui:placeholder": "Provide a brief description (~20 words)",
      "ui:options": {
        "rows": 5
      }
    },
    "hostOrganism": {
      "ui:widget": "radio",
      "ui:inline": "true"
    },
    "reactiveSpecies": {
      "ui:widget": "select",
      "ui:inline": "true"
    },
    "clonality": {
      "ui:widget": "select",
      "ui:inline": "true"
    }
  },
  "conjugate": {
    "ui:widget": "radio",
    "ui:options": {
      "inline": true
    }
  },
  "cloneId": {
    "ui:placeholder": "e.g. 2D1, EP1879Y"
  },
  "uniprotId": {
    "ui:placeholder": "e.g. P21359"
  },
  "developmentPublicationDOI": {
    "ui:placeholder": "e.g. 10.1000/xyz123"
  },
  "usagePublicationDOIs": {
    "ui:options": {
      "addButtonText": "Add Another DOI",
      "itemTitle": "DOI",
      "orderable": false
    }
  },
  "itemAcquisition": {
    "ui:widget": "radio"
  },
  "developerContactEmail": {
    "ui:placeholder": "developer@institution.edu"
  },
  "vendor": {
    "ui:placeholder": "e.g. Cell Signaling Technology"
  },
  "catalogURL": {
    "ui:placeholder": "https://"
  },
  "additionalDetails": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 3
    }
  },
  "contactEmail": {
    "ui:placeholder": "your@email.com"
  },
  "resourceType": {
    "ui:widget": "hidden"
  }
}
