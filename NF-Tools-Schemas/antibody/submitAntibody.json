{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submit Antibody",
  "type": "object",
  "properties": {
    "basicInfo": {
      "type": "object",
      "title": "Antibody Information",
      "properties": {
        "antibodyName": {
          "type": "string",
          "title": "Name of Antibody"
        },
        "synonyms": {
          "type": "string",
          "title": "Synonyms"
        },
        "description": {
          "type": "string",
          "title": "Description (~20 words)"
        },
        "hostOrganism": {
          "type": "string",
          "title": "Host Organism",
          "enum": [
            "Mouse",
            "Rabbit",
            "Unknown"
          ]
        },
        "reactiveSpecies": {
          "type": "object",
          "title": "Reactive Species",
          "properties": {
            "Human": {
              "type": "boolean"
            },
            "Mouse": {
              "type": "boolean"
            },
            "Rat": {
              "type": "boolean"
            },
            "Chicken": {
              "type": "boolean"
            },
            "Rabbit": {
              "type": "boolean"
            },
            "Pig": {
              "type": "boolean"
            },
            "Dog": {
              "type": "boolean"
            },
            "Zebrafish": {
              "type": "boolean"
            },
            "Fish": {
              "type": "boolean"
            },
            "Non-humanprimate": {
              "type": "boolean"
            },
            "GuineaPig": {
              "type": "boolean"
            },
            "Hamster": {
              "type": "boolean"
            },
            "Cow": {
              "type": "boolean"
            },
            "Monkey": {
              "type": "boolean"
            },
            "Avian": {
              "type": "boolean"
            },
            "Horse": {
              "type": "boolean"
            },
            "Rodent": {
              "type": "boolean"
            },
            "Drosophila": {
              "type": "boolean"
            },
            "Unknown": {
              "type": "boolean"
            }
          }
        },
        "developerName": {
          "type": "string",
          "title": "Developer Name"
        },
        "developerAffiliation": {
          "type": "string",
          "title": "Developer Affiliation"
        }
      },
      "required": [
        "antibodyName",
        "description",
        "hostOrganism",
        "reactiveSpecies"
      ]
    },
    "conjugate": {
      "type": "string",
      "title": "Conjugated",
      "enum": [
        "Conjugated",
        "Non-conjugated"
      ]
    },
    "targetAntigen": {
      "type": "string",
      "title": "Target Antigen"
    },
    "cloneId": {
      "type": "string",
      "title": "Clone ID",
      "description": "Clone identifier if monoclonal (e.g. 2D1, EP1879Y)."
    },
    "uniprotId": {
      "type": "string",
      "title": "UniProt ID",
      "description": "UniProt accession for the target protein (e.g. P21359 for NF1). Find at uniprot.org."
    },
    "clonality": {
      "type": "string",
      "title": "Clonality",
      "enum": [
        "Monoclonal",
        "Polyclonal",
        "Secondary",
        "Recombinant",
        "Control",
        "Cocktail",
        "Isotope Control",
        "Unknown"
      ]
    },
    "developmentPublicationDOI": {
      "type": "string",
      "title": "Development Publication DOI (where tool was first described)",
      "pattern": "^$|^10\\."
    },
    "usagePublicationDOIs": {
      "type": "array",
      "title": "Usage Publication DOI(s)",
      "items": {
        "type": "string",
        "title": "DOI",
        "pattern": "^$|^10\\."
      }
    },
    "itemAcquisition": {
      "type": "string",
      "title": "How to acquire",
      "enum": [
        "Contact Developer",
        "Purchase from Vendor",
        "Other"
      ],
      "default": "Contact Developer"
    },
    "resourceType": {
      "type": "string",
      "title": "Resource Type",
      "default": "Antibody"
    },
    "contactEmail": {
      "type": "string",
      "title": "Your Contact Email (optional)",
      "description": "Your email address for follow-up questions about this submission.",
      "format": "email"
    }
  },
  "required": [
    "basicInfo",
    "itemAcquisition",
    "targetAntigen",
    "uniprotId"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Contact Developer"
          }
        }
      },
      "then": {
        "properties": {
          "developerContactEmail": {
            "type": "string",
            "title": "Developer Contact Email (optional)",
            "format": "email"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Purchase from Vendor"
          }
        }
      },
      "then": {
        "properties": {
          "vendor": {
            "type": "string",
            "title": "Vendor Name"
          },
          "catalogNumber": {
            "type": "string",
            "title": "Catalog Number"
          },
          "catalogURL": {
            "type": "string",
            "title": "Link to vendor page"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Other"
          }
        }
      },
      "then": {
        "properties": {
          "additionalDetails": {
            "type": "string",
            "title": "Please provide additional details."
          }
        },
        "required": [
          "additionalDetails"
        ]
      }
    }
  ]
}
