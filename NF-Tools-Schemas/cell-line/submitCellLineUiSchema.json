{
  "basicInfo": {
    "description": {
      "ui:widget": "textarea",
      "ui:placeholder": "Provide a brief description (~20 words)",
      "ui:options": {
        "rows": 5
      }
    },
    "species": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    },
    "sex": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    },
    "race": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    },
    "age": {
      "ui:widget": "updown"
    }
  },
  "cellLineCategory": {
    "ui:widget": "select"
  },
  "organ": {
    "ui:widget": "select"
  },
  "strProfile": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 3
    }
  },
  "cellLineGeneticDisorder": {
    "ui:widget": "radio"
  },
  "cellLineManifestation": {
    "ui:widget": "select"
  },
  "tissue": {
    "ui:widget": "select"
  },
  "cultureMedia": {
    "ui:widget": "textarea",
    "ui:placeholder": "e.g. DMEM supplemented with 10% FBS, 1% pen-strep",
    "ui:options": {
      "rows": 3
    }
  },
  "pkpdCapabilities": {
    "ui:widget": "checkboxes"
  },
  "mechanismOfActionValidation": {
    "ui:widget": "checkboxes"
  },
  "pediatricSuitability": {
    "ui:widget": "radio"
  },
  "timelineToResults": {
    "ui:widget": "select"
  },
  "developmentPublicationDOI": {
    "ui:placeholder": "e.g. 10.1000/xyz123"
  },
  "usagePublicationDOIs": {
    "ui:options": {
      "addButtonText": "Add Another DOI",
      "itemTitle": "DOI",
      "orderable": false
    }
  },
  "itemAcquisition": {
    "ui:widget": "radio"
  },
  "developerContactEmail": {
    "ui:placeholder": "developer@institution.edu"
  },
  "vendor": {
    "ui:placeholder": "e.g. ATCC"
  },
  "catalogURL": {
    "ui:placeholder": "https://"
  },
  "additionalDetails": {
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 3
    }
  },
  "contactEmail": {
    "ui:placeholder": "your@email.com"
  },
  "resourceType": {
    "ui:widget": "hidden"
  }
}
