{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submit Clinical Assessment Tool",
  "type": "object",
  "properties": {
    "basicInfo": {
      "type": "object",
      "title": "Assessment Tool Information",
      "properties": {
        "assessmentName": { "type": "string", "title": "Name of Assessment Tool" },
        "synonyms": { "type": "string", "title": "Synonyms or Abbreviations" },
        "description": { "type": "string", "title": "Description (~20-50 words)" },
        "assessmentType": {
          "type": "string",
          "title": "Type of Assessment",
          "enum": ["Quality of Life", "Pain Assessment", "Functional Assessment", "Cognitive Assessment", "Symptom Scale", "Psychological Assessment", "Patient-Reported Outcome", "Other"]
        },
        "targetPopulation": {
          "type": "string",
          "title": "Target Population",
          "enum": ["Pediatric", "Adult", "Elderly", "General", "Disease-Specific"]
        },
        "diseaseSpecific": {
          "type": "string",
          "title": "Disease-Specific or General?",
          "enum": ["Yes - NF-specific", "No - General", "Adapted for NF"]
        },
        "numberOfItems": { "type": "string", "title": "Number of Items/Questions" },
        "scoringMethod": { "type": "string", "title": "Scoring Method/Methodology" },
        "validatedLanguages": {
          "type": "array",
          "title": "Validated Languages",
          "items": { "type": "string" }
        },
        "psychometricProperties": { "type": "string", "title": "Psychometric Properties (reliability, validity)" },
        "administrationTime": { "type": "string", "title": "Typical Administration Time" },
        "availabilityStatus": {
          "type": "string",
          "title": "Availability Status",
          "enum": ["Freely Available", "License Required", "Permission Required", "Proprietary", "Unknown"]
        },
        "licensingRequirements": { "type": "string", "title": "Licensing/Permission Requirements" },
        "digitalVersion": {
          "type": "string",
          "title": "Digital/Electronic Version Available?",
          "enum": ["Yes", "No", "In Development", "Unknown"]
        },
        "cognitiveAndBehavioralDomains": {
          "type": "array",
          "title": "Cognitive/Behavioral Domains Assessed",
          "description": "Specific cognitive or behavioral outcome domains captured by this tool (relevant for NF-related brain tumor and CNS manifestations).",
          "items": {
            "type": "string",
            "enum": [
              "Attention / ADHD",
              "Executive function",
              "Memory",
              "Learning disabilities",
              "Language / communication",
              "Anxiety",
              "Depression / mood",
              "Social cognition",
              "Academic achievement",
              "Adaptive behavior",
              "Global cognitive ability",
              "Other"
            ]
          },
          "uniqueItems": true
        },
        "regulatoryAcceptanceHistory": {
          "type": "string",
          "title": "Regulatory Acceptance History",
          "description": "Known FDA/EMA endorsement or acceptance of this tool as a clinical outcome assessment (COA) for trials."
        },
        "rrid": { "type": "string", "title": "RRID (if available)" },
        "developerName": { "type": "string", "title": "Developer Name" },
        "developerAffiliation": { "type": "string", "title": "Developer Affiliation" }
      },
      "required": ["assessmentName", "assessmentType", "targetPopulation"]
    },
    "developmentPublicationDOI": {
      "type": "string",
      "title": "Development Publication DOI (where tool was first described)",
      "pattern": "^$|^10\\."
    },
    "usagePublicationDOIs": {
      "type": "array",
      "title": "Usage Publication DOI(s)",
      "items": { "type": "string", "title": "DOI", "pattern": "^$|^10\\." }
    },
    "itemAcquisition": {
      "type": "string",
      "title": "How to acquire",
      "enum": [
        "Freely Available Online",
        "Contact Developer/Author",
        "Other"
      ]
    },
    "contactEmail": {
      "type": "string",
      "title": "Your Contact Email (optional)",
      "description": "Your email address for follow-up questions about this submission.",
      "format": "email"
    },
    "resourceType": { "type": "string", "title": "Resource Type", "default": "Clinical Assessment Tool" }
  },
  "required": ["basicInfo", "itemAcquisition"],
  "allOf": [
    {
      "if": { "properties": { "itemAcquisition": { "const": "Freely Available Online" } } },
      "then": {
        "properties": {
          "toolURL": { "type": "string", "title": "Tool URL", "format": "uri" }
        }
      }
    },
    {
      "if": { "properties": { "itemAcquisition": { "const": "Contact Developer/Author" } } },
      "then": {
        "properties": {
          "developerContactEmail": { "type": "string", "title": "Developer Contact Email (optional)", "format": "email" }
        }
      }
    },
    {
      "if": { "properties": { "itemAcquisition": { "const": "Other" } } },
      "then": {
        "properties": {
          "additionalDetails": { "type": "string", "title": "Please provide additional details." }
        },
        "required": ["additionalDetails"]
      }
    }
  ]
}
