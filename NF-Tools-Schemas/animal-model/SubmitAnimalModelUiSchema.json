    "ui:widget": "select"
  },
  "bbbIntegrityStatus": {
    "ui:widget": "select"
  },
  "routeOfAdministration": {
    "ui:widget": "checkboxes"
  },
  "pkpdCapabilities": {
    "ui:widget": "checkboxes"
  },
  "mechanismOfActionValidation": {
    "ui:widget": "checkboxes"
  },
  "pediatricSuitability": {
    "ui:widget": "radio"
  },
