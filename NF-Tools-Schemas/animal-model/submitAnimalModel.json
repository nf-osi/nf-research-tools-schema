{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Submit Animal Model",
  "type": "object",
  "properties": {
    "basicInfo": {
      "type": "object",
      "title": "Animal Model Information",
      "properties": {
        "animalModelName": {
          "type": "string",
          "title": "Name of Animal Model"
        },
        "synonyms": {
          "type": "string",
          "title": "Synonyms"
        },
        "description": {
          "type": "string",
          "title": "Description (~20 words)"
        },
        "species": {
          "type": "string",
          "title": "Species",
          "enum": [
            "Mouse",
            "Rat",
            "Pig",
            "Zebrafish",
            "Fruit Fly",
            "Other"
          ]
        },
        "developerName": {
          "type": "string",
          "title": "Developer Name"
        },
        "developerAffiliation": {
          "type": "string",
          "title": "Developer Affiliation"
        }
      },
      "required": [
        "animalModelName",
        "description",
        "species"
      ]
    },
    "backgroundStrain": {
      "type": "string",
      "title": "Background Strain",
      "examples": [
        "C57BL/6"
      ]
    },
    "backgroundSubstrain": {
      "type": "string",
      "title": "Background Substrain",
      "examples": [
        "C57BL/6J"
      ]
    },
    "strainNomenclature": {
      "type": "string",
      "title": "Strain Nomenclature"
    },
    "animalModelGeneticDisorder": {
      "type": "string",
      "title": "Genetic Disorder",
      "enum": [
        "Neurofibromatosis Type 1",
        "Neurofibromatosis Type 2",
        "No known disease",
        "Schwannomatosis"
      ]
    },
    "animalModelOfManifestation": {
      "type": "string",
      "title": "Manifestation",
      "enum": [
        "No Symptoms",
        "Acute Myeloid Leukemia",
        "Astrocytoma",
        "Cognition",
        "Growth",
        "Heart Malformation",
        "High Grade Glioma",
        "Low Grade Glioma",
        "Malignant Peripheral Nerve Sheath Tumor",
        "Metabolic Function",
        "Neural Crest Hyperplasia",
        "Optic Nerve Glioma",
        "Plexiform Neurofibroma",
        "Spinal Development",
        "Other"
      ]
    },
    "transplantationType": {
      "type": "string",
      "title": "Transplantation Type",
      "description": "If this model involves cell/tumor transplantation, specify the type.",
      "enum": [
        "",
        "Allograft",
        "Syngraft",
        "Xenograft",
        "Isograft",
        "None"
      ]
    },
    "animalState": {
      "type": "string",
      "title": "Animal State",
      "enum": [
        "",
        "Alive",
        "Deceased",
        "Unknown"
      ]
    },
    "generation": {
      "type": "string",
      "title": "Generation",
      "description": "Filial generation (e.g. F0, F1, F2) or other generation descriptor."
    },
    "alleleType": {
      "type": "string",
      "title": "Allele Type",
      "enum": [
        "Conditional ready",
        "Constitutively active",
        "Dominant negative",
        "Humanized sequence",
        "Hypomorph",
        "Inducible",
        "Inserted expressed sequence",
        "Knockdown",
        "Modified isoform(s)",
        "No functional change",
        "Null/knockout",
        "RMCE-Ready",
        "Recombinase",
        "Reporter",
        "Transactivator",
        "Transposase",
        "Transposon concatemer",
        "Other"
      ]
    },
    "affectedGeneSymbol": {
      "type": "string",
      "title": "Affected Gene Symbol"
    },
    "mutationTypes": {
      "type": "object",
      "title": "Mutation Types",
      "properties": {
        "Disruption caused by insertion of vector": {
          "type": "boolean"
        },
        "Duplication": {
          "type": "boolean"
        },
        "Insertion": {
          "type": "boolean"
        },
        "Insertion of gene trap vector": {
          "type": "boolean"
        },
        "Intergenic deletion": {
          "type": "boolean"
        },
        "Intragenic deletion": {
          "type": "boolean"
        },
        "Inversion": {
          "type": "boolean"
        },
        "Loss of heterozygosity (unspecified mechanism)": {
          "type": "boolean"
        },
        "Nucleotide repeat expansion": {
          "type": "boolean"
        },
        "Nucleotide substitutions": {
          "type": "boolean"
        },
        "Single point mutation": {
          "type": "boolean"
        },
        "Translocation": {
          "type": "boolean"
        },
        "Transposon insertion": {
          "type": "boolean"
        },
        "Viral insertion": {
          "type": "boolean"
        },
        "Other": {
          "type": "boolean"
        }
      }
    },
    "proteinVariation": {
      "type": "string",
      "title": "Protein Variation"
    },
    "sequenceVariation": {
      "type": "string",
      "title": "Sequence Variation"
    },
    "inducedVsDevelopmental": {
      "type": "string",
      "title": "Model Category",
      "description": "Whether this is an induced tumor model (tumor introduced experimentally) or a developmental model (tumor arises through genetic programming).",
      "enum": [
        "",
        "Induced Tumor Model",
        "Developmental Model",
        "Unknown"
      ]
    },
    "bbbIntegrityStatus": {
      "type": "string",
      "title": "Blood-Brain Barrier Integrity",
      "description": "Whether the blood-brain barrier is intact, compromised, or not applicable in this model.",
      "enum": [
        "",
        "Intact",
        "Compromised",
        "Not Applicable",
        "Unknown"
      ]
    },
    "routeOfAdministration": {
      "type": "array",
      "title": "Supported Drug Administration Routes",
      "description": "Drug delivery routes that have been validated or are feasible in this model.",
      "items": {
        "type": "string",
        "enum": [
          "Oral",
          "Intravenous (IV)",
          "Intraperitoneal (IP)",
          "Intracranial",
          "Subcutaneous",
          "Topical",
          "Intranasal",
          "Other"
        ]
      },
      "uniqueItems": true
    },
    "pkpdCapabilities": {
      "type": "array",
      "title": "PK/PD Measurement Capabilities",
      "description": "Pharmacokinetic and pharmacodynamic measurements that can be performed in this model.",
      "items": {
        "type": "string",
        "enum": [
          "Drug concentration in plasma",
          "Drug concentration in brain/CNS tissue",
          "Drug concentration in tumor",
          "Drug concentration in CSF",
          "Target engagement measurement",
          "Pathway modulation (e.g., pERK, pAKT)",
          "Biomarker response",
          "Metabolite profiling",
          "Metabolic pathway flux analysis",
          "Drug-drug interaction assessment",
          "Other"
        ]
      },
      "uniqueItems": true
    },
    "mechanismOfActionValidation": {
      "type": "array",
      "title": "Validated Drug Mechanisms",
      "description": "Drug mechanisms of action that have been successfully tested in this model.",
      "items": {
        "type": "string",
        "enum": [
          "MEK inhibitors",
          "RAS pathway (non-MEK)",
          "mTOR inhibitors",
          "VEGF/angiogenesis",
          "CDK inhibitors",
          "HDAC inhibitors",
          "Other kinase inhibitors",
          "Immunotherapy",
          "Chemotherapy",
          "Other"
        ]
      },
      "uniqueItems": true
    },
    "pediatricSuitability": {
      "type": "string",
      "title": "Age Relevance",
      "description": "Whether this model is suitable for studying pediatric, adult, or both age groups.",
      "enum": [
        "",
        "Pediatric",
        "Adult",
        "Both",
        "Unknown"
      ]
    },
    "timelineToResults": {
      "type": "string",
      "title": "Typical Timeline to Results",
      "description": "Estimated time from experiment start to primary endpoint readout.",
      "enum": [
        "",
        "Less than 1 month",
        "1\u20133 months",
        "3\u20136 months",
        "6\u201312 months",
        "More than 12 months",
        "Unknown"
      ]
    },
    "modelLimitations": {
      "type": "string",
      "title": "Known Model Limitations",
      "description": "Explicit description of what this model does NOT recapitulate or where it may produce false positive/negative results."
    },
    "clinicalTranslationHistory": {
      "type": "string",
      "title": "Clinical Translation History",
      "description": "Known instances where findings from this model did or did not translate to human clinical outcomes."
    },
    "regulatoryAcceptanceHistory": {
      "type": "string",
      "title": "Regulatory Acceptance History",
      "description": "Known FDA/EMA precedents where data from this model type supported a regulatory submission or approval."
    },
    "mtaRequired": {
      "type": "boolean",
      "title": "MTA Required?",
      "description": "Whether a Material Transfer Agreement is required to access this model."
    },
    "ngnriRepositoryStatus": {
      "type": "boolean",
      "title": "Deposited in NGNRI Repository?",
      "description": "Whether this model is deposited in the NF Gene Network Research Initiative repository for equitable access."
    },
    "developmentPublicationDOI": {
      "type": "string",
      "title": "Development Publication DOI (where tool was first described)",
      "pattern": "^$|^10\\."
    },
    "usagePublicationDOIs": {
      "type": "array",
      "title": "Usage Publication DOI(s)",
      "items": {
        "type": "string",
        "title": "DOI",
        "pattern": "^$|^10\\."
      }
    },
    "itemAcquisition": {
      "type": "string",
      "title": "How to acquire",
      "enum": [
        "Contact Developer",
        "Purchase from Vendor",
        "Other"
      ],
      "default": "Contact Developer"
    },
    "resourceType": {
      "type": "string",
      "title": "Resource Type",
      "default": "Animal Model"
    },
    "contactEmail": {
      "type": "string",
      "title": "Your Contact Email (optional)",
      "description": "Your email address for follow-up questions about this submission.",
      "format": "email"
    }
  },
  "required": [
    "basicInfo",
    "itemAcquisition",
    "animalModelGeneticDisorder",
    "animalModelOfManifestation"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "basicInfo": {
            "properties": {
              "species": {
                "const": "Other"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "basicInfo": {
            "properties": {
              "otherSpecies": {
                "type": "string",
                "title": "Other species name"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Contact Developer"
          }
        }
      },
      "then": {
        "properties": {
          "developerContactEmail": {
            "type": "string",
            "title": "Developer Contact Email (optional)",
            "format": "email"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Purchase from Vendor"
          }
        }
      },
      "then": {
        "properties": {
          "vendor": {
            "type": "string",
            "title": "Vendor Name"
          },
          "catalogNumber": {
            "type": "string",
            "title": "Catalog Number"
          },
          "catalogURL": {
            "type": "string",
            "title": "Link to vendor page"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "itemAcquisition": {
            "const": "Other"
          }
        }
      },
      "then": {
        "properties": {
          "additionalDetails": {
            "type": "string",
            "title": "Please provide additional details."
          }
        },
        "required": [
          "additionalDetails"
        ]
      }
    }
  ]
}
